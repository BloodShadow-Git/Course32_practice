@page "/"
@using System.Net.Http.Json
@using System.Net.Http.Headers
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JSRuntime
@inject Frontend.Services.AuthState AuthStateService

<PageTitle>Панель Администратора</PageTitle>

<div class="container mt-5">
    @if (!AuthStateService.IsLoggedIn)
    {
        <div class="card mx-auto border-danger" style="max-width: 400px;">
            <div class="card-body">
                <h3 class="card-title mb-4 text-danger">Вход для Админа</h3>
                <input @bind="Username" class="form-control mb-3" placeholder="Имя администратора" />
                <input @bind="Password" type="password" class="form-control mb-3" placeholder="Пароль" />
                <button class="btn btn-danger w-100" @onclick="LoginAsync">Вход в систему</button>
                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="alert alert-danger mt-3">@ErrorMessage</div>
                }
            </div>
        </div>
    }
    else if (!AuthStateService.IsAdmin)
    {
        <div class="alert alert-danger">
            Доступ запрещен. Эта страница только для администраторов.
            <button class="btn btn-sm btn-outline-danger ms-3" @onclick="LogoutAsync">Выйти</button>
        </div>
    }
    else
    {
        <div class="card border-danger">
            <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
                <h3 class="mb-0">Администрирование API Ключей</h3>
                <button class="btn btn-sm btn-light text-danger" @onclick="LogoutAsync">Выйти</button>
            </div>
            <div class="card-body">
                <div class="row mb-5">
                    <div class="col-md-6">
                        <div class="card bg-light border-0">
                            <div class="card-body">
                                <h5 class="card-title text-primary">Мои ключи администратора</h5>
                                <p class="text-muted small">Вы можете создать API ключ для внешних интеграций от имени администратора.</p>
                                
                                <div class="d-flex gap-2 mb-3">
                                    <input @bind="NewKeyName" class="form-control form-control-sm" placeholder="Имя ключа (напр., Admin Script)" />
                                    <button class="btn btn-sm btn-primary text-nowrap" @onclick="GenerateApiKey">Сгенерировать</button>
                                </div>
                                
                                @if (MyAdminKeys != null && MyAdminKeys.Any())
                                {
                                    <ul class="list-group list-group-sm text-start" style="font-size: 0.85rem;">
                                        @foreach (var key in MyAdminKeys)
                                        {
                                            <li class="list-group-item d-flex justify-content-between align-items-center @(!key.IsActive ? "bg-light text-muted" : "")">
                                                <div>
                                                    <strong>@key.Name</strong> 
                                                    @if(!key.IsActive) { <span class="badge bg-danger ms-1">Отключен</span> }
                                                    <br/>
                                                    <code class="text-muted user-select-all">@key.Key</code>
                                                </div>
                                                <div class="text-end">
                                                    <span class="badge bg-secondary mb-2">Вызовов: @key.CallsCount</span><br/>
                                                    <button class="btn btn-sm @(key.IsActive ? "btn-warning" : "btn-success")" 
                                                            @onclick="() => ToggleMyAdminKey(key.Id)">
                                                        @(key.IsActive ? "Выкл" : "Вкл")
                                                    </button>
                                                    <button class="btn btn-sm btn-danger ms-1" 
                                                            @onclick="() => DeleteMyAdminKey(key.Id)">
                                                        Удалить
                                                    </button>
                                                </div>
                                            </li>
                                        }
                                    </ul>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5>Все ключи в системе:</h5>
                    <button class="btn btn-outline-secondary" @onclick="LoadAllKeys">Обновить список</button>
                </div>

                @if (AllKeys == null)
                {
                    <p>Загрузка данных...</p>
                }
                else if (!AllKeys.Any())
                {
                    <p class="text-muted">В системе пока нет ключей.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover align-middle text-center">
                            <thead class="table-dark">
                                <tr>
                                    <th>Игрок</th>
                                    <th>Имя ключа</th>
                                    <th>Ключ</th>
                                    <th>Статус</th>
                                    <th>Вызовы</th>
                                    <th>Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var key in AllKeys)
                                {
                                    <tr class="@(!key.IsActive ? "table-secondary text-muted" : "")">
                                        <td><strong>@key.PlayerName</strong></td>
                                        <td>@key.Name</td>
                                        <td><code class="px-2 py-1 bg-light rounded border">@key.Key</code></td>
                                        <td>
                                            @if (key.IsActive)
                                            {
                                                <span class="badge bg-success">Активен</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Отключен</span>
                                            }
                                        </td>
                                        <td><span class="badge bg-secondary">@key.CallsCount</span></td>
                                        <td>
                                            <button class="btn btn-sm @(key.IsActive ? "btn-warning" : "btn-success")" 
                                                    @onclick="() => ToggleKeyStatus(key.Id)">
                                                @(key.IsActive ? "Отключить" : "Включить")
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                <div class="d-flex justify-content-between align-items-center mb-3 mt-5">
                    <h5>Игроки в системе:</h5>
                    <button class="btn btn-outline-secondary" @onclick="LoadAllPlayers">Обновить игроков</button>
                </div>

                @if (AllPlayers == null)
                {
                    <p>Загрузка данных...</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-bordered align-middle text-center" style="font-size: 0.9rem;">
                            <thead class="table-dark">
                                <tr>
                                    <th>Игрок</th>
                                    <th>Статус / Баланс</th>
                                    <th>Пароль (BCrypt)</th>
                                    <th>Инвентарь</th>
                                    <th>API Ключи</th>
                                    <th>Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var player in AllPlayers)
                                {
                                    <tr class="@(player.IsBlocked ? "table-secondary text-muted" : "")">
                                        <td>
                                            <strong>@player.Username</strong>
                                            <div class="small">ID: @player.Id</div>
                                        </td>
                                        <td>
                                            @if (player.IsAdmin)
                                            {
                                                <span class="badge bg-danger mb-1">Админ</span><br/>
                                            }
                                            @if (player.IsBlocked)
                                            {
                                                <span class="badge bg-secondary mb-1">Заблокирован</span><br/>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success mb-1">Активен</span><br/>
                                            }
                                            <span class="badge bg-info text-dark">Баланс: @player.Balance</span>
                                        </td>
                                        <td style="max-width: 150px; overflow-wrap: anywhere;">
                                            <code class="text-muted" style="font-size: 0.75rem;">@player.PasswordHash</code>
                                        </td>
                                        <td class="text-start">
                                            @if (player.Inventory != null && player.Inventory.Any())
                                            {
                                                <ul class="list-unstyled mb-0">
                                                @foreach(var inv in player.Inventory)
                                                {
                                                    <li>- @inv.ItemName <span class="badge bg-primary rounded-pill">x @inv.Count</span></li>
                                                }
                                                </ul>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">Пусто</span>
                                            }
                                        </td>
                                        <td class="text-start">
                                            @if (player.ApiKeys != null && player.ApiKeys.Any())
                                            {
                                                <ul class="list-unstyled mb-0">
                                                @foreach(var key in player.ApiKeys)
                                                {
                                                    <li>
                                                        <span class="@(key.IsActive ? "text-success" : "text-danger")">●</span> 
                                                        @key.Name <span class="badge bg-secondary">@key.CallsCount</span><br/>
                                                        <code class="small text-muted">@key.Key</code>
                                                    </li>
                                                }
                                                </ul>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">Нет ключей</span>
                                            }
                                        </td>
                                        <td>
                                            @if (!player.IsAdmin)
                                            {
                                                <button class="btn btn-sm w-100 mb-1 @(player.IsBlocked ? "btn-success" : "btn-warning")" 
                                                        @onclick="() => TogglePlayerBlock(player.Id)">
                                                    @(player.IsBlocked ? "Разблокировать" : "Блокировать")
                                                </button>
                                                <button class="btn btn-sm w-100 btn-danger" 
                                                        @onclick="() => DeletePlayer(player.Id)">
                                                    Удалить
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        <small class="text-muted">* В соответствии с правилами безопасности, оригинальные пароли пользователей не хранятся в открытом виде. Вы видите только защищенные хэши, сгенерированные алгоритмом BCrypt.</small>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private string Username = "";
    private string Password = "";
    private string ErrorMessage = "";
    private string Token = "";
    private string NewKeyName = "";
    private List<AdminApiKeyInfo>? AllKeys;
    private List<ApiKeyInfo>? MyAdminKeys;
    private List<AdminPlayerInfo>? AllPlayers;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var savedToken = await JSRuntime.InvokeAsync<string>("cookieManager.getCookie", "authToken");
            var savedIsAdmin = await JSRuntime.InvokeAsync<string>("cookieManager.getCookie", "authIsAdmin");
            
            if (!string.IsNullOrEmpty(savedToken) && savedIsAdmin == "true")
            {
                Token = savedToken;
                AuthStateService.SetLoginState(true, true);
                await LoadAllKeys();
                await LoadAllPlayers();
                await LoadMyAdminKeys();
                StateHasChanged();
            }
        }
    }
    
    private async Task LoginAsync()
    {
        if (string.IsNullOrWhiteSpace(Username) || string.IsNullOrWhiteSpace(Password))
        {
            ErrorMessage = "Введите логин и пароль";
            return;
        }

        var client = HttpClientFactory.CreateClient("PlayerClient");
        var response = await client.PostAsJsonAsync("/api/auth/login", new { Username, Password });

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<AuthResult>();
            if (result != null)
            {
                Token = result.Token;
                AuthStateService.SetLoginState(true, result.IsAdmin);
                ErrorMessage = "";
                
                await JSRuntime.InvokeVoidAsync("cookieManager.setCookie", "authToken", Token, 7);
                await JSRuntime.InvokeVoidAsync("cookieManager.setCookie", "authIsAdmin", result.IsAdmin ? "true" : "false", 7);
                
                if (result.IsAdmin)
                {
                    await LoadAllKeys();
                    await LoadAllPlayers();
                    await LoadMyAdminKeys();
                }
            }
        }
        else
        {
            ErrorMessage = "Неверный логин или пароль";
        }
    }
    
    private async Task LogoutAsync()
    {
        await JSRuntime.InvokeVoidAsync("cookieManager.eraseCookie", "authToken");
        await JSRuntime.InvokeVoidAsync("cookieManager.eraseCookie", "authIsAdmin");
        AuthStateService.SetLoginState(false);
        Token = "";
    }

    private async Task LoadAllKeys()
    {
        var client = HttpClientFactory.CreateClient("AdminClient");
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", Token);
        
        var keys = await client.GetFromJsonAsync<List<AdminApiKeyInfo>>("/api/admin/keys");
        if (keys != null)
        {
            AllKeys = keys;
            StateHasChanged();
        }
    }

    private async Task ToggleKeyStatus(int keyId)
    {
        var client = HttpClientFactory.CreateClient("AdminClient");
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", Token);
        
        var response = await client.PostAsync($"/api/admin/keys/{keyId}/toggle", null);
        if (response.IsSuccessStatusCode)
        {
            await LoadAllKeys();
        }
    }

    private async Task LoadAllPlayers()
    {
        var client = HttpClientFactory.CreateClient("AdminClient");
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", Token);
        
        var players = await client.GetFromJsonAsync<List<AdminPlayerInfo>>("/api/admin/players");
        if (players != null)
        {
            AllPlayers = players;
            StateHasChanged();
        }
    }

    private async Task TogglePlayerBlock(int playerId)
    {
        var client = HttpClientFactory.CreateClient("AdminClient");
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", Token);
        
        var response = await client.PostAsync($"/api/admin/players/{playerId}/toggle-block", null);
        if (response.IsSuccessStatusCode)
        {
            await LoadAllPlayers();
        }
    }

    private async Task DeletePlayer(int playerId)
    {
        var client = HttpClientFactory.CreateClient("AdminClient");
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", Token);
        
        var response = await client.DeleteAsync($"/api/admin/players/{playerId}");
        if (response.IsSuccessStatusCode)
        {
            await LoadAllPlayers();
            await LoadAllKeys();
        }
    }

    private async Task LoadMyAdminKeys()
    {
        var client = HttpClientFactory.CreateClient("PlayerClient");
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", Token);
        
        var keys = await client.GetFromJsonAsync<List<ApiKeyInfo>>("/api/auth/keys");
        if (keys != null)
        {
            MyAdminKeys = keys;
            StateHasChanged();
        }
    }

    private async Task GenerateApiKey()
    {
        if (string.IsNullOrWhiteSpace(NewKeyName)) return;

        var client = HttpClientFactory.CreateClient("PlayerClient");
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", Token);
        
        var response = await client.PostAsJsonAsync("/api/auth/generate-key", new { Name = NewKeyName });
        if (response.IsSuccessStatusCode)
        {
            NewKeyName = "";
            await LoadMyAdminKeys(); // Перезагружаем список
            await LoadAllKeys(); // Обновляем глобальную таблицу админа
        }
    }

    private async Task ToggleMyAdminKey(int keyId)
    {
        var client = HttpClientFactory.CreateClient("PlayerClient");
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", Token);
        
        var response = await client.PostAsync($"/api/auth/keys/{keyId}/toggle", null);
        if (response.IsSuccessStatusCode)
        {
            await LoadMyAdminKeys();
            await LoadAllKeys();
        }
    }

    private async Task DeleteMyAdminKey(int keyId)
    {
        var client = HttpClientFactory.CreateClient("PlayerClient");
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", Token);
        
        var response = await client.DeleteAsync($"/api/auth/keys/{keyId}");
        if (response.IsSuccessStatusCode)
        {
            await LoadMyAdminKeys();
            await LoadAllKeys();
        }
    }

    public class ApiKeyInfo
    {
        public int Id { get; set; }
        public string Key { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public int CallsCount { get; set; }
        public bool IsActive { get; set; }
    }

    public class AdminApiKeyInfo
    {
        public int Id { get; set; }
        public string PlayerName { get; set; } = string.Empty;
        public string Key { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public int CallsCount { get; set; }
        public bool IsActive { get; set; }
    }
    
    public class AdminPlayerInfo
    {
        public int Id { get; set; }
        public string Username { get; set; } = string.Empty;
        public int Balance { get; set; }
        public bool IsAdmin { get; set; }
        public bool IsBlocked { get; set; }
        public string PasswordHash { get; set; } = string.Empty;
        public List<AdminApiKeyInfo> ApiKeys { get; set; } = new();
        public List<PlayerItem> Inventory { get; set; } = new();
    }
    
    public class PlayerItem
    {
        public int ItemId { get; set; }
        public string ItemName { get; set; } = string.Empty;
        public int Count { get; set; }
    }
    
    public class AuthResult
    {
        public string Token { get; set; } = string.Empty;
        public bool IsAdmin { get; set; }
    }
}