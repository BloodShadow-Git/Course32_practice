@page "/apikeys"
@using System.Net.Http.Json
@using System.Net.Http.Headers
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JSRuntime

<PageTitle>Мои API Ключи</PageTitle>

<div class="container mt-5">
    <div class="card">
        <div class="card-header bg-dark text-white">
            <h3 class="mb-0">Управление API Ключами</h3>
        </div>
        <div class="card-body">
            @if (!IsLoggedIn)
            {
                <div class="alert alert-warning">
                    Пожалуйста, сначала <a href="/">войдите в систему</a>.
                </div>
            }
            else
            {
                <div class="mb-4 p-3 bg-light border rounded">
                    <h5>Создать новый ключ</h5>
                    <div class="d-flex gap-2">
                        <input @bind="NewKeyName" class="form-control" placeholder="Имя ключа (напр., My Super App)" />
                        <button class="btn btn-primary text-nowrap" @onclick="GenerateApiKey">Сгенерировать</button>
                    </div>
                </div>

                <h5>Ваши ключи:</h5>
                @if (UserApiKeys == null)
                {
                    <p>Загрузка ключей...</p>
                }
                else if (!UserApiKeys.Any())
                {
                    <p class="text-muted">У вас пока нет сгенерированных ключей.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle">
                            <thead class="table-dark">
                                <tr>
                                    <th>Имя</th>
                                    <th>Ключ (X-Api-Key)</th>
                                    <th>Статус</th>
                                    <th>Вызовов</th>
                                    <th>Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var key in UserApiKeys)
                                {
                                    <tr class="@(!key.IsActive ? "table-secondary text-muted" : "")">
                                        <td><strong>@key.Name</strong></td>
                                        <td><code class="user-select-all px-2 py-1 bg-light rounded border">@key.Key</code></td>
                                        <td>
                                            @if (key.IsActive)
                                            {
                                                <span class="badge bg-success">Активен</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Отключен</span>
                                            }
                                        </td>
                                        <td><span class="badge bg-secondary">@key.CallsCount</span></td>
                                        <td>
                                            <button class="btn btn-sm @(key.IsActive ? "btn-warning" : "btn-success") mb-1 w-100" 
                                                    @onclick="() => ToggleKeyStatus(key.Id)">
                                                @(key.IsActive ? "Выключить" : "Включить")
                                            </button>
                                            <button class="btn btn-sm btn-danger w-100" 
                                                    @onclick="() => DeleteKey(key.Id)">
                                                Удалить
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <button class="btn btn-outline-secondary mt-3" @onclick="LoadApiKeys">Обновить статистику</button>
                }
            }
        </div>
    </div>
</div>

@code {
    private bool IsLoggedIn = false;
    private string Token = "";
    private string NewKeyName = "";
    private List<ApiKeyInfo>? UserApiKeys;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var savedToken = await JSRuntime.InvokeAsync<string>("cookieManager.getCookie", "authToken");
                if (!string.IsNullOrEmpty(savedToken))
                {
                    Token = savedToken;
                    IsLoggedIn = true;
                    await LoadApiKeys();
                    StateHasChanged();
                }
                else
                {
                    StateHasChanged();
                }
            }
            catch (Exception) { /* Handle pre-rendering issues silently */ }
        }
    }

    private async Task LoadApiKeys()
    {
        var client = HttpClientFactory.CreateClient("PlayerClient");
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", Token);
        
        var keys = await client.GetFromJsonAsync<List<ApiKeyInfo>>("/api/auth/keys");
        if (keys != null)
        {
            UserApiKeys = keys;
            StateHasChanged();
        }
    }

    private async Task GenerateApiKey()
    {
        if (string.IsNullOrWhiteSpace(NewKeyName)) return;

        var client = HttpClientFactory.CreateClient("PlayerClient");
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", Token);
        
        var response = await client.PostAsJsonAsync("/api/auth/generate-key", new { Name = NewKeyName });
        if (response.IsSuccessStatusCode)
        {
            NewKeyName = "";
            await LoadApiKeys(); // Перезагружаем список
        }
    }

    private async Task ToggleKeyStatus(int keyId)
    {
        var client = HttpClientFactory.CreateClient("PlayerClient");
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", Token);
        
        var response = await client.PostAsync($"/api/auth/keys/{keyId}/toggle", null);
        if (response.IsSuccessStatusCode)
        {
            await LoadApiKeys();
        }
    }

    private async Task DeleteKey(int keyId)
    {
        var client = HttpClientFactory.CreateClient("PlayerClient");
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", Token);
        
        var response = await client.DeleteAsync($"/api/auth/keys/{keyId}");
        if (response.IsSuccessStatusCode)
        {
            await LoadApiKeys();
        }
    }

    public class ApiKeyInfo
    {
        public int Id { get; set; }
        public string Key { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public int CallsCount { get; set; }
        public bool IsActive { get; set; }
    }
}