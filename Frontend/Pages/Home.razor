@page "/"
@using R3
@using System.Net.Http.Json
@using System.Net.Http.Headers
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JSRuntime
@inject Frontend.Services.AuthState AuthStateService
@implements IDisposable

<PageTitle>Click & Buy</PageTitle>

<div class="container text-center mt-5">
    @if (!IsLoggedIn)
    {
        <div class="card mx-auto" style="max-width: 400px;">
            <div class="card-body">
                <h3 class="card-title mb-4">Вход в игру</h3>
                <input @bind="Username" class="form-control mb-3" placeholder="Имя игрока" />
                <input @bind="Password" type="password" class="form-control mb-3" placeholder="Пароль" />
                
                <div class="d-flex gap-2">
                    <button class="btn btn-primary w-50" @onclick="LoginAsync">Войти</button>
                    <button class="btn btn-outline-primary w-50" @onclick="RegisterAsync">Регистрация</button>
                </div>
                
                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="alert alert-danger mt-3">@ErrorMessage</div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="row">
            <!-- Зона кликера и инвентаря -->
            <div class="col-md-6 mb-4">
                <div class="card h-100 bg-light">
                    <div class="card-body d-flex flex-column justify-content-center align-items-center">
                        <div class="d-flex justify-content-between w-100 align-items-start">
                            <h2>Игрок: @Username</h2>
                            <button class="btn btn-sm btn-danger" @onclick="LogoutAsync">Выйти</button>
                        </div>
                        <h4 class="text-success mb-2">Баланс: @Balance баллов</h4>
                        <div class="mb-4 text-muted small">Сила клика: @ClickPower</div>
                        
                        <button class="btn btn-warning btn-lg rounded-circle shadow mb-4" 
                                style="width: 200px; height: 200px; font-size: 2rem; transition: transform 0.1s;"
                                @onclick="OnClick">
                            КЛИК!
                        </button>
                        
                        <div class="w-100 mt-4 text-start">
                            <h5>Инвентарь:</h5>
                            @if (Inventory != null && Inventory.Any())
                            {
                                <ul class="list-group">
                                    @foreach (var inv in Inventory)
                                    {
                                        <li class="list-group-item d-flex justify-content-between align-items-center">
                                            @inv.ItemName
                                            <span class="badge bg-primary rounded-pill">x @inv.Count</span>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <p class="text-muted">Инвентарь пуст</p>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Зона магазина -->
            <div class="col-md-6 mb-4">
                <div class="card h-100">
                    <div class="card-header bg-dark text-white">
                        <h3 class="mb-0">Магазин</h3>
                    </div>
                    <div class="card-body">
                        @if (Items == null)
                        {
                            <p>Загрузка товаров...</p>
                        }
                        else
                        {
                            <ul class="list-group text-start">
                                @foreach (var item in Items)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <div>
                                            <strong>@item.Name</strong><br/>
                                            <small class="text-muted">@item.Description</small>
                                        </div>
                                        <div class="text-end">
                                            <span class="badge bg-primary rounded-pill mb-1">@item.Price баллов</span><br/>
                                            <button class="btn btn-sm btn-outline-success" @onclick="() => BuyItem(item.Id)">Купить</button>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool IsLoggedIn = false;
    private string Username = "";
    private string Password = "";
    private string ErrorMessage = "";
    private int UserId;
    private int Balance = 0;
    private string Token = "";
    
    private StoreItem[]? Items;
    private List<PlayerItem> Inventory = new();

    // Реактивный поток для кликов (R3)
    private Subject<Unit> _clickSubject = new Subject<Unit>();
    private IDisposable? _clickSubscription;

    protected override async Task OnInitializedAsync()
    {
        // R3: Собираем клики в пакеты каждые 500 миллисекунд (Chunk)
        _clickSubscription = _clickSubject
            .Chunk(TimeSpan.FromMilliseconds(500))
            .Where(clicks => clicks.Length > 0) // Отправляем только если были клики
            .Subscribe(async clicks => await SendClicksToServer(clicks.Length));
            
        await CheckSessionAsync();
    }
    
    private async Task CheckSessionAsync()
    {
        try
        {
            var savedToken = await JSRuntime.InvokeAsync<string>("cookieManager.getCookie", "authToken");
            var savedUserIdStr = await JSRuntime.InvokeAsync<string>("cookieManager.getCookie", "authUserId");
            var savedUsername = await JSRuntime.InvokeAsync<string>("cookieManager.getCookie", "authUsername");
            var savedIsAdmin = await JSRuntime.InvokeAsync<string>("cookieManager.getCookie", "authIsAdmin");
            
            if (!string.IsNullOrEmpty(savedToken) && int.TryParse(savedUserIdStr, out int uid))
            {
                Token = savedToken;
                UserId = uid;
                Username = savedUsername ?? "Player";
                bool isAdmin = savedIsAdmin == "true";
                IsLoggedIn = true;
                AuthStateService.SetLoginState(true, isAdmin);
                
                await RefreshBalance();
                await LoadStoreItems();
            }
        }
        catch (Exception) { /* JS Interop might fail during pre-rendering */ }
    }
    
    private async Task SaveSessionAsync(bool isAdmin)
    {
        await JSRuntime.InvokeVoidAsync("cookieManager.setCookie", "authToken", Token, 7);
        await JSRuntime.InvokeVoidAsync("cookieManager.setCookie", "authUserId", UserId.ToString(), 7);
        await JSRuntime.InvokeVoidAsync("cookieManager.setCookie", "authUsername", Username, 7);
        await JSRuntime.InvokeVoidAsync("cookieManager.setCookie", "authIsAdmin", isAdmin ? "true" : "false", 7);
    }
    
    private async Task LogoutAsync()
    {
        await JSRuntime.InvokeVoidAsync("cookieManager.eraseCookie", "authToken");
        await JSRuntime.InvokeVoidAsync("cookieManager.eraseCookie", "authUserId");
        await JSRuntime.InvokeVoidAsync("cookieManager.eraseCookie", "authUsername");
        await JSRuntime.InvokeVoidAsync("cookieManager.eraseCookie", "authIsAdmin");
        
        IsLoggedIn = false;
        AuthStateService.SetLoginState(false);
        Token = "";
        Password = "";
    }

    private int ClickPower 
    {
        get
        {
            if (Inventory == null || !Inventory.Any()) return 1;
            int power = 1;
            foreach (var item in Inventory)
            {
                if (item.ItemId == 1) power += 1 * item.Count;
                if (item.ItemId == 2) power += 3 * item.Count;
                if (item.ItemId == 3) power += 5 * item.Count;
                if (item.ItemId == 4) power += 10 * item.Count;
                if (item.ItemId == 5) power += 25 * item.Count;
                if (item.ItemId == 6) power += 50 * item.Count;
                if (item.ItemId == 7) power += 100 * item.Count;
                if (item.ItemId == 8) power += 250 * item.Count;
                if (item.ItemId == 9) power += 500 * item.Count;
                if (item.ItemId == 10) power += 1000 * item.Count;
            }
            return power;
        }
    }

    private void OnClick()
    {
        int power = ClickPower;
        // Немедленно обновляем локальный баланс для отзывчивости интерфейса
        Balance += power; 
        
        // Отправляем пакет кликов через Subject (R3 соберет их)
        // Чтобы сервер начислил именно power баллов, нам нужно отправить power событий OnNext.
        // Или лучше изменить логику так, чтобы клиент не рассчитывал это, но для игры-кликера 
        // с отправкой пачками мы отправляем количество "виртуальных кликов"
        for (int i = 0; i < power; i++) 
        {
            _clickSubject.OnNext(Unit.Default);
        }
    }

    private async Task LoginAsync()
    {
        await AuthenticateAsync("/api/auth/login");
    }
    
    private async Task RegisterAsync()
    {
        var client = HttpClientFactory.CreateClient("PlayerClient");
        var response = await client.PostAsJsonAsync("/api/auth/register", new { Username, Password });

        if (response.IsSuccessStatusCode)
        {
            ErrorMessage = "Успешная регистрация. Теперь вы можете войти.";
            // Автоматически логиним после регистрации
            await LoginAsync();
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            ErrorMessage = $"Ошибка: {error}";
        }
    }
    
    private async Task AuthenticateAsync(string endpoint)
    {
        if (string.IsNullOrWhiteSpace(Username) || string.IsNullOrWhiteSpace(Password))
        {
            ErrorMessage = "Введите логин и пароль";
            return;
        }

        var client = HttpClientFactory.CreateClient("PlayerClient");
        var response = await client.PostAsJsonAsync(endpoint, new { Username, Password });

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<AuthResult>();
            if (result != null)
            {
                Token = result.Token;
                UserId = result.UserId;
                Username = result.Username;
                IsLoggedIn = true;
                AuthStateService.SetLoginState(true, result.IsAdmin);
                ErrorMessage = "";
                
                await SaveSessionAsync(result.IsAdmin);
                await RefreshBalance();
                await LoadStoreItems();
            }
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            ErrorMessage = $"Ошибка: {error}";
        }
    }

    private async Task SendClicksToServer(int clickCount)
    {
        if (!IsLoggedIn || string.IsNullOrEmpty(Token)) return;
        
        var client = HttpClientFactory.CreateClient("ClickClient");
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", Token);
        
        await client.PostAsJsonAsync("/api/click", new { Clicks = clickCount });
    }

    private async Task RefreshBalance()
    {
        var client = HttpClientFactory.CreateClient("PlayerClient");
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", Token);
        
        var response = await client.GetAsync($"/api/player/{UserId}/balance");
        if (response.IsSuccessStatusCode)
        {
            var info = await response.Content.ReadFromJsonAsync<PlayerInfo>();
            if (info != null)
            {
                Balance = info.Balance;
                Inventory = info.Inventory ?? new List<PlayerItem>();
                StateHasChanged();
            }
        }
        else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await LogoutAsync(); // Токен протух
        }
    }

    private async Task LoadStoreItems()
    {
        var client = HttpClientFactory.CreateClient("StoreClient");
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", Token);
        
        var response = await client.GetAsync("/api/store/items");
        if (response.IsSuccessStatusCode)
        {
            Items = await response.Content.ReadFromJsonAsync<StoreItem[]>();
            StateHasChanged();
        }
    }

    private async Task BuyItem(int itemId)
    {
        var client = HttpClientFactory.CreateClient("StoreClient");
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", Token);
        
        var response = await client.PostAsJsonAsync("/api/store/buy", new { ItemId = itemId });
        if (response.IsSuccessStatusCode)
        {
            // Покупка успешна, нужно обновить баланс и инвентарь
            await RefreshBalance();
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            Console.WriteLine($"Ошибка покупки: {error}");
        }
    }

    public void Dispose()
    {
        _clickSubscription?.Dispose();
        _clickSubject.Dispose();
    }

    // Классы (DTO) для парсинга ответов
    public class AuthResult
    {
        public string Token { get; set; } = string.Empty;
        public int UserId { get; set; }
        public string Username { get; set; } = string.Empty;
        public string? ApiKey { get; set; }
        public bool IsAdmin { get; set; }
    }

    public class ApiKeyInfo
    {
        public string Key { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public int CallsCount { get; set; }
    }

    public class PlayerInfo
    {
        public int Balance { get; set; }
        public List<PlayerItem> Inventory { get; set; } = new();
    }

    public class PlayerItem
    {
        public int ItemId { get; set; }
        public string ItemName { get; set; } = string.Empty;
        public int Count { get; set; }
    }

    public class StoreItem
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public int Price { get; set; }
    }
}